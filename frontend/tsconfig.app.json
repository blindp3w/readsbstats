{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    // Audit-13 A13-043: incremental strict-mode adoption. strictNullChecks
    // shipped in v2.3.x; noImplicitAny followed in v2.5.x (audit follow-up).
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": { "@/*": ["./src/*"] },
    // TS 6.0 deprecated `baseUrl` in favour of paths-only resolution.
    // We keep `baseUrl` for now to preserve the existing tsserver UX
    // (Cmd-click on `@/foo`); silence the deprecation warning until the
    // wider TS 7 migration.
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "test"]
}
