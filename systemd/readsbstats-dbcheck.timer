[Unit]
# Do NOT add `Requires=readsbstats-dbcheck.service`. A `Requires=` on a timer's
# [Unit] makes `systemctl start <timer>` (e.g. update.sh's `enable --now`) launch
# the service immediately — running the integrity check on every deploy. The
# timer triggers the service on schedule via its implicit Unit= (same basename).
Description=Weekly readsbstats DB quick_check (Sun 03:30)

[Timer]
OnCalendar=Sun *-*-* 03:30:00
Persistent=true

[Install]
WantedBy=timers.target
