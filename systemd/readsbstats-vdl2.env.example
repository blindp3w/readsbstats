# VDL2 / ACARS feature — shared environment, read by BOTH readsbstats-web and
# readsbstats-vdl2 (via EnvironmentFile=-/etc/readsbstats/vdl2.env). This one
# file is the single flag that gates the whole feature.
#
# Install: copy to /etc/readsbstats/vdl2.env, set the flag, then
#   sudo systemctl restart readsbstats-web
#   sudo systemctl enable --now readsbstats-vdl2
#
# When false (default) the web surfaces stay hidden and the ingest service, even
# if enabled, starts and exits cleanly (dormant).

RSBS_VDL2_ENABLED=false

# Optional tunables (defaults shown):
# RSBS_VDL2_DB_PATH=/mnt/ext/readsbstats/vdl2.db
# RSBS_VDL2_RETENTION_DAYS=90
# RSBS_VDL2_UDP_HOST=127.0.0.1
# RSBS_VDL2_UDP_PORT=5555
# RSBS_VDL2_DECODER=vdlm2dec
# RSBS_VDL2_RAW_MAX=8192
