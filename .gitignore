frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/.eslintcache
# TypeScript incremental-build caches; one per tsconfig.*.json
*.tsbuildinfo

# Playwright (HTML report + intermediate per-run artefacts)
playwright-report/
test-results/

# Internal / private project material (not for public repo)
internal_docs/

# Session continuity (internal, not for public repo)
NOTES.md
scratchpad.md

# AI assistant / agent context — ALL local-only, never public.
# Hard internal/public split: agent context + internal_docs/ stay off GitHub;
# only docs/ (incl. docs/decisions ADRs) and code are public.
# NOTE: gitignore has NO inline comments — keep each pattern on its own line.
# Claude Code dir (settings.local.json, commands, hooks):
.claude/
# CLAUDE.md at any depth + CLAUDE.local.md / CLAUDE.old.md / future variants:
CLAUDE*.md
.clauderc
# Other agent tools (Codex, Gemini, Cursor, Aider, Serena MCP, Copilot):
AGENTS.md
GEMINI.md
.cursor/
.cursorrules
.aider*
.serena/
# Copilot only — do NOT ignore all of .github/ (workflows are public):
.github/copilot-instructions.md
# MCP server configs may embed tokens / private endpoints:
.mcp.json
mcp.json

# Playwright MCP output (screenshots / console / snapshots)
.playwright-mcp/

# superpowers brainstorming companion artifacts
.superpowers/

# superpowers process artifacts (specs/plans) — distilled into docs/decisions
# when architecturally significant; the raw workflow docs stay local-only.
docs/superpowers/
